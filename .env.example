# PostgreSQL connection string used by Prisma.
# Local dev example:
#   DATABASE_URL="postgresql://postgres:postgres@localhost:5432/federated_need?schema=public"
# Hosted (Neon/Supabase/Railway): paste the connection string they give you.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/federated_need?schema=public"

# Platform-admin gate. ADMIN_PASSWORD is what you type on /admin/login.
# ADMIN_SESSION_SECRET is the opaque value stored in the httpOnly session
# cookie — set it to a long random string (e.g. `openssl rand -hex 32`).
ADMIN_PASSWORD="change-me"
ADMIN_SESSION_SECRET="change-me-to-a-long-random-string"

# Secret used to sign user (volunteer / NGO-admin) session JWTs.
# Set it to a long random string (e.g. `openssl rand -hex 32`).
AUTH_SESSION_SECRET="change-me-to-a-long-random-string"

# Web Push (browser notifications). Generate a pair with
# `npx web-push generate-vapid-keys`. NEXT_PUBLIC_ exposes the public key to the
# browser; keep the private key secret. VAPID_SUBJECT is a mailto: contact.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:you@example.com"

# Google Maps JavaScript API key — powers the live hotspot map on /network.
# Leave unset to use the built-in SVG fallback. Enable the "Maps JavaScript
# API" in Google Cloud and restrict the key to your domains.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# Google Gemini API Key for NLP extraction (Information Ingestion & OCR Refinement)
# Get yours here: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your_api_key_here"
GEMINI_MODEL="gemini-3.1-flash-lite-preview"

# Email notifications (Gmail SMTP). EMAIL_NOTIFICATIONS_ENABLED is the global
# on/off switch — set "true" to enable. GMAIL_APP_PASSWORD is a Gmail App
# Password (Google Account → Security → 2-Step Verification → App passwords);
# your normal Gmail password will NOT work. APP_URL is the absolute base URL
# used for links inside the emails.
EMAIL_NOTIFICATIONS_ENABLED="false"
GMAIL_USER="you@example.com"
GMAIL_APP_PASSWORD=""
APP_URL="http://localhost:3000"
